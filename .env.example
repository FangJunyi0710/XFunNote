# ============================================================
# 数据库用户名，拼接为 data/{用户名}.db
# 若未设置，默认回退为 data/default.db
XFUN_USER="username"

# ============================================================
# 管理员启动密钥（bootstrap），用于前期引导和数据库管理操作（/db/* 路由）
# 后续建议通过 /api/v0/tokens API 管理普通 Token
ROOT_TOKEN="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# HTTPS / SSL 配置
# 启用后前端 Vite 开发服务器会自动读取证书以 HTTPS 模式启动
# 可使用 scripts/gen_cert.sh 生成本地自签名证书
SSL_CERT_PATH="./certs/cert.pem"
SSL_KEY_PATH="./certs/key.pem"

# HTTPS 模式下是否启用热重载（设为 true 可在开发 HTTPS 时自动重启）
UVICORN_RELOAD="false"

# 文档开关，可开启/关闭 /docs Swagger UI
SHOW_DOCS="false"

# ============================================================
# DeepSeek API Key
LLM_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# DeepSeek API 端点（兼容 Anthropic 格式）
LLM_BASE_URL="https://api.deepseek.com/anthropic"
# 使用模型名
LLM_MODEL="deepseek-v4-flash"

# 后端服务监听端口
BACKEND_PORT=8000
# 前端 HTTPS 开启的端口
VITE_HTTPS_PORT=8443
# 前端 HTTP 开启的端口
VITE_HTTP_PORT=8080
# 使用的主机名，影响前端重定向服务及证书生成（scripts/gen_cert.sh 会读取此值作为证书 CN 和 SAN）。
# 若不使用 mDNS 且希望局域网设备通过 IP 访问，请将此值设为本机当前 IP 地址（否则需确保该主机名在局域网内可解析）。
VITE_HOST="xfunnote.local"
